# Copy to .env.dev / .env.staging / .env.prod and fill in.
# NEVER commit the filled-in files — .gitignore already excludes .env.*

# ---- environment ----------------------------------------------------
ENVIRONMENT=dev            # dev | staging | prod
DEBUG=true                 # MUST be false in production
API_PORT=8000

# ---- database -------------------------------------------------------
# POSTGRES_HOST is "localhost" when the API runs on your machine and
# "postgres" when it runs inside docker (compose overrides it for you).
POSTGRES_USER=closet
POSTGRES_PASSWORD=change_me
POSTGRES_DB=closet_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_ECHO=false

# ---- security -------------------------------------------------------
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
MFA_CHALLENGE_MINUTES=5

# ---- first-run administrator ---------------------------------------
# If BOTH are set and no administrator exists, one is created at startup.
# The account is flagged "must change password", so this value is a
# SINGLE-USE credential: the admin must replace it at first login before
# anything else works. Leave blank to create the admin with the CLI instead
# (scripts/manage_admin.py create).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrateur ClosET

# ---- accounts -------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_RESET_HOURS=2
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
TOTP_ISSUER=ClosET
ADMIN_REQUIRES_2FA=true

# ---- misc -----------------------------------------------------------
CORS_ORIGINS=["*"]         # restrict to the admin/back-office origin in prod
